# ═══════════════════════════════════════════════════════════════
# Root .env — dùng cho docker-compose
# Copy file này thành .env và điền giá trị thật
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=rootpassword

# MongoDB Express UI (chỉ dùng với profile dev)
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASS=adminpass

# ── JWT (iam-service + api-gateway dùng chung) ───────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex_string
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace_with_another_64_char_hex_string
JWT_REFRESH_EXPIRES_IN=7d

# ── Internal Secret (api-gateway → bff-service) ──────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=replace_with_32_char_hex_string

# ── Rate Limit ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Bcrypt ────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── HTTP Timeout ──────────────────────────────────────────────────
HTTP_TIMEOUT_MS=8000

# ── Email (iam-service) ───────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourapp.com

# ── Client URL (reset password link) ─────────────────────────────
CLIENT_URL=http://localhost:5173
